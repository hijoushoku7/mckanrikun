# API サーバー設定(コピーして .env を作成)
PORT=8080
DB_PATH=./data/app.db

# セッション Cookie
SESSION_COOKIE_NAME=mck_session
SESSION_TTL_SEC=604800
# TLS(リバースプロキシ)配下に置く場合は true
COOKIE_SECURE=false

# CORS で許可するフロントエンドのオリジン
WEB_ORIGIN=http://localhost:3000

# 初期 admin 作成(db:seed 用)。パスワード未指定ならランダム生成して表示。
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=

# Docker Engine API
DOCKER_SOCKET=/var/run/docker.sock
# コンテナ状態ポーリング間隔(ミリ秒)
STATUS_POLL_MS=5000
