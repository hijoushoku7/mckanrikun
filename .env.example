# docker compose(本番デプロイ)用の環境変数。コピーして .env を作成。

# 各 MC サーバーの /data を置く【ホストの絶対パス】(必須)。
# api/ftp 両コンテナにこのパスでマウントされる。
SERVER_DATA_ROOT=/opt/mc/servers

# 公開ポート(ホスト側)
API_PORT=8080
WEB_PORT=3000

# ブラウザから到達できる API の URL(web のビルド時に埋め込まれる)。
# 下の IP は例。LAN の他端末からも使うなら "サーバーの実プライベート IP" にする
# (localhost はサーバー本機のブラウザ以外から繋がらない)。変更時は --build で再ビルド。
NEXT_PUBLIC_API_BASE=http://192.168.1.10:8080
# api の CORS 許可オリジン(= web の公開 URL)。同様にサーバーの実 IP に合わせる。
WEB_ORIGIN=http://192.168.1.10:3000
# リバースプロキシ + TLS 配下なら true
COOKIE_SECURE=false

# 初回 admin(起動時に自動作成。再作成は `docker compose run --rm api node dist/db/seed.js`)
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=change-me-please

# FTP(MOD 配置)
FTP_PASSWORD=change-me-too
FTP_USER=mcadmin
FTP_PORT=21
FTP_PUBLISH_HOST=192.168.1.10
FTP_PASSIVE_PORT_START=30000
FTP_PASSIVE_PORT_END=30009
